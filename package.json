{
  "name": "obsidian-gdrive-sync",
  "version": "0.2.0",
  "description": "Bidirectional Google Drive sync for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "node pack.mjs"
  },
  "keywords": ["obsidian", "google-drive", "sync"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "googleapis": "^140.0.0"
  }
}
